datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["views"]
}

enum Role {
  CUSTOMER
  ADMIN
}

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  passwordHash         String    @map("password_hash")
  role                 Role      @default(CUSTOMER)
  isEmailVerified      Boolean   @default(false) @map("is_email_verified")
  verificationToken    String?   @unique @map("verification_token")
  resetPasswordToken   String?   @unique @map("reset_password_token")
  resetPasswordExpires DateTime? @map("reset_password_expires")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  profileId String?  @unique @map("profile_id")
  profile   Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  refreshTokens RefreshToken[]
  notifications Notification[]

  @@map("users")
}

model Profile {
  id           String  @id @default(uuid())
  name         String
  phone        String
  image        String?
  address      String?
  addressNotes String? @map("address_notes")
  provinceId   String? @map("province_id")
  cityId       String? @map("city_id")
  latitude     Float?
  longitude    Float?

  user User?

  orders  Order[]
  reviews Review[]

  @@map("profiles")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@map("refresh_tokens")
}

model Product {
  id                 String              @id @default(uuid())
  sku                String              @unique
  serialNumber       String?             @unique @map("serial_number")
  name               String
  price              Decimal
  buyPrice           Decimal             @default(0) @map("buy_price")
  brand              String
  category           String              @default("General")
  description        String?
  stock              Int                 @default(0)
  images             String[]            @default([])
  specifications     Json                @default("{}")
  condition          String              @default("NEW")
  warranty           String?
  weight             Int                 @default(1500)
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  deletedAt          DateTime?           @map("deleted_at")
  orderItems         OrderItem[]
  reviews            Review[]
  purchaseOrderItems PurchaseOrderItem[]

  @@map("products")
}

model Order {
  id                 String      @id @default(uuid())
  profileId          String      @map("profile_id")
  profile            Profile     @relation(fields: [profileId], references: [id])
  total_grand        Decimal
  shippingCost       Decimal     @default(0) @map("shipping_cost")
  shippingService    String?     @map("shipping_service")
  status             OrderStatus @default(PENDING)
  shippingAddr       Json        @map("shipping_addr")
  phone              String
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  items              OrderItem[]
  payment            Payment?
  reviews            Review[]
  trackingNo         String?     @map("tracking_no")
  estimatedDays      Int?        @map("estimated_days")
  shippedAt          DateTime?   @map("shipped_at")
  deliveryNotifiedAt DateTime?   @map("delivery_notified_at")
  taxAmount          Decimal     @default(0) @map("tax_amount")
  appFee             Decimal     @default(0) @map("app_fee")

  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String  @map("order_id")
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String  @map("product_id")
  product     Product @relation(fields: [productId], references: [id])
  qty         Int
  unitPrice   Decimal @map("unit_price")
  total_price Decimal

  @@map("order_item")
}

model Payment {
  id          String        @id @default(uuid())
  orderId     String        @unique @map("order_id")
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider    String
  providerId  String?       @map("provider_id")
  snapToken   String?       @map("snap_token")
  redirectUrl String?       @map("redirect_url")
  amount      Decimal
  status      PaymentStatus @default(PENDING)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  paidAt      DateTime?     @map("paid_at")

  @@map("payments")
}

model Review {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  order     Order    @relation(fields: [orderId], references: [id])
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id])
  profileId String   @map("profile_id")
  profile   Profile  @relation(fields: [profileId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("reviews")
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  REFUNDED
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("notifications")
}

model ContactMessage {
  id        String   @id @default(uuid())
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  subject   String
  phone     String
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}

model PurchaseOrder {
  id                  String              @id @default(uuid())
  receiptUrl          String              @map("receipt_url")
  totalItemsOnReceipt Int                 @map("total_items_on_receipt")
  notes               String?
  items               PurchaseOrderItem[]
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String        @map("purchase_order_id")
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String        @map("product_id")
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Int

  @@map("purchase_order_item")
}

view SalesReportView {
  orderId      String   @unique @map("order_id")
  orderDate    DateTime @map("order_date")
  customerName String?  @map("customer_name")
  totalAmount  Decimal  @map("total_amount")
  totalProfit  Decimal  @map("total_profit")

  @@map("sales_reports_view")
}

view IncomingGoodsReportView {
  poId          String   @unique @map("po_id")
  poDate        DateTime @map("po_date")
  receiptUrl    String   @map("receipt_url")
  notes         String?  @map("notes")
  totalQuantity Int      @map("total_quantity")
  totalCost     Decimal  @map("total_cost")

  @@map("incoming_goods_reports_view")
}
