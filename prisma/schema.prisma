datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["views"]
}

enum Role {
  CUSTOMER
  ADMIN
}

model User {
  id                   String    @id @default(uuid()) @db.Uuid @map("user_id")
  email                String    @unique @db.VarChar(50)
  passwordHash         String    @map("password_hash") @db.VarChar(255)
  role                 Role      @default(CUSTOMER)
  resetPasswordToken   String?   @unique @map("reset_password_token") @db.VarChar(255)
  resetPasswordExpires DateTime? @map("reset_password_expires")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  profileId String?  @unique @db.Uuid @map("profile_id")
  profile   Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  register      Register?
  refreshTokens RefreshToken[]
  notifications Notification[]

  @@map("users")
}

model Register {
  id                String  @id @default(uuid()) @db.Uuid @map("register_id")
  isEmailVerified   Boolean @default(false) @map("is_email_verified")
  verificationToken String? @unique @map("verification_token") @db.VarChar(255)
  
  userId            String  @unique @db.Uuid @map("user_id")
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("registers")
}

model Profile {
  id           String  @id @default(uuid()) @db.Uuid @map("profile_id")
  name         String  @db.VarChar(150)
  phone        String  @db.VarChar(25)
  image        String? @db.Text
  address      String? @db.VarChar(255)
  addressNotes String? @map("address_notes") @db.VarChar(255)
  provinceId   String? @db.Uuid @map("province_id")
  cityId       String? @db.Uuid @map("city_id")
  latitude     Float?  @db.DoublePrecision
  longitude    Float?  @db.DoublePrecision

  user User?

  orders  Order[]
  reviews Review[]

  @@map("profiles")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@map("refresh_tokens")
}

model Brand {
  id        String    @id @default(uuid()) @db.Uuid @map("brand_id")
  name      String    @unique @db.VarChar(100)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  products  Product[]

  @@map("brands")
}

model Condition {
  id        String    @id @default(uuid()) @db.Uuid @map("condition_id")
  name      String    @unique @db.VarChar(50)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  products  Product[]

  @@map("conditions")
}

enum MovementType {
  IN
  OUT
}

model MonitorStock {
  id           String   @id @default(uuid()) @db.Uuid @map("monitor_stock_id")
  productId    String   @unique @db.Uuid @map("product_id")
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  currentStock Int      @map("current_stock")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("monitor_stock")
}

view StockReportView {
  productId    String  @unique @map("product_id")
  product      Product @relation(fields: [productId], references: [id])
  qtyIn        Int     @map("qty_in")
  qtyOut       Int     @map("qty_out")

  @@map("stock_report_view")
}

model Product {
  id                 String              @id @default(uuid()) @db.Uuid @map("product_id")
  sku                String              @unique @db.VarChar(100)
  serialNumber       String?             @unique @map("serial_number") @db.VarChar(100)
  name               String              @db.VarChar(255)
  price              Decimal             @db.Decimal
  buyPrice           Decimal             @default(0) @map("buy_price") @db.Decimal
  brandId            String              @db.Uuid @map("brand_id")
  brand              Brand               @relation(fields: [brandId], references: [id])
  category           String              @default("General") @db.VarChar(100)
  description        String?             @db.Text
  images             Json                @default("[]")
  specifications     Json                @default("{}")
  conditionId        String              @db.Uuid @map("condition_id")
  condition          Condition           @relation(fields: [conditionId], references: [id])
  warranty           String?             @db.VarChar(100)
  weight             Int                 @default(1500)
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  deletedAt          DateTime?           @map("deleted_at")
  
  orderItems         OrderItem[]
  reviews            Review[]
  purchaseOrderItems PurchaseOrderItem[]
  monitorStock       MonitorStock?
  stockReport        StockReportView?

  @@map("products")
}

model Order {
  id                 String      @id @default(uuid()) @db.Uuid @map("order_id")
  profileId          String      @db.Uuid @map("profile_id")
  profile            Profile     @relation(fields: [profileId], references: [id])
  total_grand        Decimal     @db.Decimal
  shippingCost       Decimal     @default(0) @map("shipping_cost") @db.Decimal
  shippingService    String?     @map("shipping_service") @db.VarChar(100)
  status             OrderStatus @default(PENDING)
  shippingAddr       Json        @map("shipping_addr")
  phone              String      @db.VarChar(25)
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  trackingNo         String?     @map("tracking_no") @db.VarChar(100)
  estimatedDays      Int?        @map("estimated_days")
  shippedAt          DateTime?   @map("shipped_at")
  deliveryNotifiedAt DateTime?   @map("delivery_notified_at")
  taxAmount          Decimal     @default(0) @map("tax_amount") @db.Decimal
  appFee             Decimal     @default(0) @map("app_fee") @db.Decimal

  items              OrderItem[]
  payment            Payment?
  reviews            Review[]

  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid()) @db.Uuid @map("order_item_id")
  orderId     String  @db.Uuid @map("order_id")
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String  @db.Uuid @map("product_id")
  product     Product @relation(fields: [productId], references: [id])
  qty         Int
  unitPrice   Decimal @map("unit_price") @db.Decimal
  total_price Decimal @db.Decimal

  @@map("order_item")
}

model Payment {
  id          String        @id @default(uuid()) @db.Uuid @map("payment_id")
  orderId     String        @unique @db.Uuid @map("order_id")
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider    String        @db.VarChar(100)
  providerId  String?       @map("provider_id") @db.VarChar(255)
  snapToken   String?       @map("snap_token") @db.VarChar(255)
  redirectUrl String?       @map("redirect_url") @db.VarChar(255)
  amount      Decimal       @db.Decimal
  status      PaymentStatus @default(PENDING)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  paidAt      DateTime?     @map("paid_at")

  @@map("payments")
}

model Review {
  id        String   @id @default(uuid()) @db.Uuid @map("review_id")
  orderId   String   @db.Uuid @map("order_id")
  order     Order    @relation(fields: [orderId], references: [id])
  productId String   @db.Uuid @map("product_id")
  product   Product  @relation(fields: [productId], references: [id])
  profileId String   @db.Uuid @map("profile_id")
  profile   Profile  @relation(fields: [profileId], references: [id])
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@map("reviews")
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  REFUNDED
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid @map("notification_id")
  userId    String   @db.Uuid @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @db.VarChar(255)
  message   String   @db.Text
  type      String   @db.VarChar(50)
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("notifications")
}

model ContactMessage {
  id        String   @id @default(uuid())
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  subject   String
  phone     String
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}

model PurchaseOrder {
  id                  String              @id @default(uuid()) @db.Uuid @map("purchase_order_id")
  receiptUrl          String              @map("receipt_url") @db.VarChar(255)
  totalItemsOnReceipt Int                 @map("total_items_on_receipt")
  notes               String?             @db.Text
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  
  items               PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid()) @db.Uuid @map("purchase_order_item_id")
  purchaseOrderId String        @db.Uuid @map("purchase_order_id")
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String        @db.Uuid @map("product_id")
  product         Product       @relation(fields: [productId], references: [id])
  qty             Int

  @@map("purchase_order_item")
}
